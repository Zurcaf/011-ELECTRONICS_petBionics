; ── WiFi credentials ──────────────────────────────────────────────────────
; Copiar este ficheiro para secrets.ini e preencher os valores reais.
; secrets.ini é gitignored — nunca fazer commit de credenciais.

[secrets]
build_flags =
    -DWIFI_SSID=\"YOUR_SSID_HERE\"
    -DWIFI_PASSWORD=\"YOUR_PASSWORD_HERE\"
