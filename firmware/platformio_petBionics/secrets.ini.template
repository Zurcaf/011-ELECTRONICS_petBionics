; ── Firebase / Firestore credentials ──────────────────────────────────────
; Copy this file to secrets.ini and fill in real values.
; secrets.ini is gitignored — never commit credentials.

[secrets]
build_flags =
    -DFIRESTORE_API_KEY=\"YOUR_FIREBASE_API_KEY_HERE\"
    -DFIREBASE_PROJECT=\"YOUR_FIREBASE_PROJECT_ID_HERE\"
